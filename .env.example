# Environment: development, staging, production
NODE_ENV=development
PORT=3000
LOG_LEVEL=debug

# Database
DB_HOST=postgres
DB_PORT=5432
DB_USER=omniforge
DB_PASSWORD=omniforge
DB_NAME=omniforge
DATABASE_URL=postgresql://omniforge:omniforge@postgres:5432/omniforge

# MongoDB
MONGO_USER=omniforge
MONGO_PASSWORD=omniforge
MONGO_HOST=mongodb
MONGO_PORT=27017
MONGODB_URI=mongodb://omniforge:omniforge@mongodb:27017/omniforge

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_URL=redis://redis:6379

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_REFRESH_SECRET=your-super-secret-refresh-jwt-key-change-in-production
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Elasticsearch
ELASTICSEARCH_HOST=elasticsearch
ELASTICSEARCH_PORT=9200
ELASTICSEARCH_URL=http://elasticsearch:9200

# Qdrant (Vector DB)
QDRANT_HOST=qdrant
QDRANT_PORT=6333
QDRANT_URL=http://qdrant:6333
QDRANT_API_KEY=omniforge

# MinIO / S3
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=omniforge-assets
MINIO_USE_SSL=false
AWS_REGION=us-east-1
AWS_S3_BUCKET=omniforge-assets
AWS_S3_ACCESS_KEY_ID=
AWS_S3_SECRET_ACCESS_KEY=
STORAGE_PROVIDER=minio

# File Upload
MAX_FILE_SIZE=5368709120
ALLOWED_MIME_TYPES=*/*

# Jaeger (Tracing)
JAEGER_AGENT_HOST=jaeger
JAEGER_AGENT_PORT=6831

# NATS
NATS_SERVERS=nats://nats:4222

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:3000
NEXT_PUBLIC_GRAPHQL_URL=http://localhost:3000/graphql

# OAuth Providers
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:3000/auth/google/callback

GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_CALLBACK_URL=http://localhost:3000/auth/github/callback

MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_CALLBACK_URL=http://localhost:3000/auth/microsoft/callback

APPLE_CLIENT_ID=
APPLE_CALLBACK_URL=http://localhost:3000/auth/apple/callback

# AI Provider Keys (Optional)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=
STABILITY_API_KEY=
ELEVENLABS_API_KEY=

# Stripe (Billing)
STRIPE_API_KEY=
STRIPE_WEBHOOK_SECRET=

# Security
CORS_ORIGIN=*
ENABLE_PROFILING=false
RATE_LIMIT_ENABLED=true
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Email (Optional)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@omniforge.ai

# Terraform / Infrastructure
AWS_REGION=us-east-1
TF_VAR_environment=development
TF_VAR_kubernetes_version=1.28
TF_VAR_db_master_password=your-secure-password
TF_VAR_backup_retention_period=7
